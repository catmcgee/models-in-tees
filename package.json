{
  "name": "tee-ai-private-gpt2",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p tsconfig.server.json",
    "build:frontend": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "llm:test": ".venv/bin/python src/model/model_runner.py selftest",
    "train:sae": ".venv/bin/python scripts/train_sae.py",
    "api:test": "tsx scripts/smoke.ts",
    "audit:public": "tsx scripts/publicAudit.ts",
    "chain:test": "tsx scripts/devnetCommit.ts",
    "test": "npm run llm:test && npm run typecheck && npm run build && npm run api:test"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
